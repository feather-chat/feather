{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "verbatimModuleSyntax": true,
    "declaration": false,
    "sourceMap": false,
    "skipLibCheck": true,
    "types": ["k6"]
  },
  "include": ["src"]
}
