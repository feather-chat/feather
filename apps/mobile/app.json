{
  "expo": {
    "name": "Enzyme",
    "slug": "enzyme",
    "version": "0.1.0",
    "scheme": "enzyme",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#4F46E5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "im.enzyme.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "im.enzyme.mobile"
    },
    "updates": {
      "url": "https://u.expo.dev/dd56c866-7a79-4c22-9da2-04047e2ec5ab",
      "codeSigningCertificate": "./certs/certificate.der",
      "codeSigningMetadata": {
        "keyid": "main",
        "alg": "rsa-v1_5-sha256"
      }
    },
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "extra": {
      "eas": {
        "projectId": "dd56c866-7a79-4c22-9da2-04047e2ec5ab"
      }
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#4F46E5",
          "defaultChannel": {
            "name": "Messages",
            "description": "New message notifications",
            "importance": 4,
            "vibrationPattern": [0, 250, 250, 250],
            "sound": "default"
          }
        }
      ],
      [
        "expo-updates",
        {
          "username": "enzyme"
        }
      ]
    ]
  }
}
