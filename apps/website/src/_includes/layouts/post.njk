---
layout: layouts/page.njk
---

<article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <!-- Post header -->
  <header class="mb-10">
    <a href="/blog/" class="inline-flex items-center gap-1 text-sm text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors mb-4">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
      </svg>
      Back to blog
    </a>
    <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 dark:text-white leading-tight">{{ title }}</h1>
    <div class="mt-4 flex items-center gap-3 text-gray-500 dark:text-gray-400">
      <time datetime="{{ date | dateFormat }}">{{ date | dateFormat }}</time>
      {% if author %}
        <span>&middot;</span>
        <span>{{ author }}</span>
      {% endif %}
    </div>
    {% if description %}
      <p class="mt-4 text-xl text-gray-600 dark:text-gray-400">{{ description }}</p>
    {% endif %}
  </header>

  <!-- Post content -->
  <div class="prose max-w-none">
    {{ content | safe }}
  </div>
</article>
