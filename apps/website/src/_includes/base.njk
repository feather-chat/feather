<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ title }}{% if title %} - {% endif %}Enzyme</title>
    <meta name="description" content="{{ description or 'Enzyme is a self-hostable team chat platform. Own your data, deploy anywhere.' }}" />

    <!-- Open Graph -->
    <meta property="og:title" content="{{ title }}{% if title %} - {% endif %}Enzyme" />
    <meta property="og:description" content="{{ description or 'Enzyme is a self-hostable team chat platform. Own your data, deploy anywhere.' }}" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
    <meta property="og:image" content="{{ site.url }}/assets/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="{{ site.url }}/assets/og-image.png" />

    <!-- Canonical -->
    <link rel="canonical" href="{{ site.url }}{{ page.url }}" />

    <!-- Favicon -->
    <link rel="icon" href="/assets/favicon.svg" type="image/svg+xml" />

    <!-- Styles -->
    <link rel="preload" href="/css/main.css" as="style" />
    <link rel="stylesheet" href="/css/main.css" />

    <!-- Theme: prevent flash -->
    <script>
      (function () {
        var s = localStorage.getItem('theme');
        if (s === 'dark' || (!s && matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <script src="/assets/js/theme.js" defer></script>
  </head>
  <body class="min-h-screen flex flex-col">
    <svg xmlns="http://www.w3.org/2000/svg" class="hidden">
      <symbol id="icon-github" viewBox="0 0 24 24">
        <path fill="currentColor" d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
      </symbol>
    </svg>
    {{ content | safe }}
  </body>
</html>
