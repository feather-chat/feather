{
  "name": "@enzyme/shared",
  "version": "0.2.0",
  "private": true,
  "sideEffects": [
    "./src/stores/*.ts",
    "./src/cache/*.ts"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@enzyme/api-client": "workspace:*"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.90.20",
    "@types/react": "~19.1.17",
    "react": "19.1.0",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  }
}
